{
  "$defs": {
    "ContextBudget": {
      "additionalProperties": false,
      "properties": {
        "compaction_threshold_pct": {
          "default": 0.7,
          "title": "Compaction Threshold Pct",
          "type": "number"
        },
        "max_retries": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Retries"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "max_tool_calls": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tool Calls"
        },
        "max_wall_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Wall Seconds"
        }
      },
      "title": "ContextBudget",
      "type": "object"
    },
    "DerivationType": {
      "enum": [
        "parser",
        "analyser",
        "build",
        "test",
        "trace",
        "llm",
        "heuristic",
        "policy",
        "review"
      ],
      "title": "DerivationType",
      "type": "string"
    },
    "EvidenceStrength": {
      "description": "Ordered from strongest to weakest.\n\nThe numeric ordering supports comparisons:\n``EvidenceStrength.hard_static > EvidenceStrength.soft_llm`` is True.\n``min([hard_static, soft_llm])`` returns ``soft_llm``.",
      "enum": [
        "hard_static",
        "hard_dynamic",
        "structured_repository",
        "calibrated_model",
        "soft_llm"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "GateStatus": {
      "enum": [
        "passed",
        "failed",
        "skipped",
        "unknown"
      ],
      "title": "GateStatus",
      "type": "string"
    },
    "GateType": {
      "enum": [
        "format",
        "lint",
        "typecheck",
        "unit_test",
        "integration_test",
        "sast",
        "secrets",
        "dependency_scan",
        "contract",
        "maintainability",
        "manifest_regression",
        "prompt_regression",
        "custom"
      ],
      "title": "GateType",
      "type": "string"
    },
    "IndexStatus": {
      "enum": [
        "fresh",
        "stale",
        "partial",
        "mixed",
        "unknown"
      ],
      "title": "IndexStatus",
      "type": "string"
    },
    "ManifestHash": {
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Hash"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "manifest_path": {
          "minLength": 1,
          "title": "Manifest Path",
          "type": "string"
        }
      },
      "required": [
        "manifest_path"
      ],
      "title": "ManifestHash",
      "type": "object"
    },
    "ModelBackendRef": {
      "additionalProperties": false,
      "properties": {
        "api_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Version"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "ModelBackendRef",
      "type": "object"
    },
    "PermissionMode": {
      "enum": [
        "read",
        "search",
        "edit",
        "execute",
        "review",
        "commit"
      ],
      "title": "PermissionMode",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Evidence provenance — required on every durable fact.\n\nEvery code-related fact must carry ``repo`` and ``snapshot``.\nLLM-derived evidence (``derivation=llm``) cannot claim hard evidence\nstrength (``hard_static`` or ``hard_dynamic``).",
      "properties": {
        "attributes": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Attributes",
          "type": "object"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_ts": {
          "minLength": 1,
          "title": "Created Ts",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/DerivationType"
        },
        "evidence_strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "repo": {
          "$ref": "#/$defs/RepoRef"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotRef"
        },
        "source_event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Event Id"
        },
        "source_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_tool": {
          "minLength": 1,
          "title": "Source Tool",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_tool",
        "repo",
        "snapshot",
        "derivation",
        "confidence",
        "evidence_strength",
        "created_ts"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "RedactionPolicy": {
      "additionalProperties": false,
      "properties": {
        "hash_paths": {
          "default": true,
          "title": "Hash Paths",
          "type": "boolean"
        },
        "policy_id": {
          "default": "default",
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "redact_command_output": {
          "default": false,
          "title": "Redact Command Output",
          "type": "boolean"
        },
        "redact_prompts": {
          "default": true,
          "title": "Redact Prompts",
          "type": "boolean"
        },
        "redact_source_files": {
          "default": false,
          "title": "Redact Source Files",
          "type": "boolean"
        }
      },
      "title": "RedactionPolicy",
      "type": "object"
    },
    "RepoRef": {
      "additionalProperties": false,
      "description": "Stable reference to a repository.",
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "RetryPolicy": {
      "additionalProperties": false,
      "properties": {
        "backoff_strategy": {
          "default": "none",
          "title": "Backoff Strategy",
          "type": "string"
        },
        "max_retries": {
          "default": 3,
          "title": "Max Retries",
          "type": "integer"
        }
      },
      "title": "RetryPolicy",
      "type": "object"
    },
    "RuntimeRef": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "name"
      ],
      "title": "RuntimeRef",
      "type": "object"
    },
    "SandboxDescriptor": {
      "additionalProperties": false,
      "properties": {
        "devcontainer_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Devcontainer Sha"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "sandbox_type": {
          "default": "none",
          "title": "Sandbox Type",
          "type": "string"
        }
      },
      "title": "SandboxDescriptor",
      "type": "object"
    },
    "SideEffectClass": {
      "enum": [
        "none",
        "read_only",
        "writes_repo",
        "writes_outside_repo",
        "executes_code",
        "network",
        "destructive",
        "release"
      ],
      "title": "SideEffectClass",
      "type": "string"
    },
    "SnapshotRef": {
      "additionalProperties": false,
      "description": "Reference to a specific repository snapshot.",
      "properties": {
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "captured_ts": {
          "minLength": 1,
          "title": "Captured Ts",
          "type": "string"
        },
        "dirty": {
          "default": false,
          "title": "Dirty",
          "type": "boolean"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "index_status": {
          "$ref": "#/$defs/IndexStatus",
          "default": "unknown"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "worktree_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worktree Snapshot Id"
        }
      },
      "required": [
        "repo_id",
        "captured_ts"
      ],
      "title": "SnapshotRef",
      "type": "object"
    },
    "SourceSpan": {
      "additionalProperties": false,
      "description": "Source location within a repository-relative file.",
      "properties": {
        "byte_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte End"
        },
        "byte_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte Start"
        },
        "encoding": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "end_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Col"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "file_path": {
          "minLength": 1,
          "title": "File Path",
          "type": "string"
        },
        "start_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Col"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "file_path",
        "start_line",
        "end_line"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "ToolPermission": {
      "additionalProperties": false,
      "properties": {
        "allowed_stages": {
          "items": {
            "type": "string"
          },
          "title": "Allowed Stages",
          "type": "array"
        },
        "approval_requirement": {
          "default": false,
          "title": "Approval Requirement",
          "type": "boolean"
        },
        "deny_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deny Reason"
        },
        "network_requirement": {
          "default": false,
          "title": "Network Requirement",
          "type": "boolean"
        },
        "path_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Scope"
        },
        "required_mode": {
          "$ref": "#/$defs/PermissionMode"
        },
        "side_effect_class": {
          "$ref": "#/$defs/SideEffectClass",
          "default": "none"
        },
        "tool_name": {
          "minLength": 1,
          "title": "Tool Name",
          "type": "string"
        }
      },
      "required": [
        "tool_name",
        "required_mode"
      ],
      "title": "ToolPermission",
      "type": "object"
    },
    "VerificationGate": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "gate_name": {
          "minLength": 1,
          "title": "Gate Name",
          "type": "string"
        },
        "gate_type": {
          "$ref": "#/$defs/GateType"
        },
        "skip_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skip Reason"
        },
        "status": {
          "$ref": "#/$defs/GateStatus",
          "default": "unknown"
        }
      },
      "required": [
        "gate_name",
        "gate_type"
      ],
      "title": "VerificationGate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "captured_ts": {
      "minLength": 1,
      "title": "Captured Ts",
      "type": "string"
    },
    "context_policy": {
      "$ref": "#/$defs/ContextBudget",
      "default": {
        "compaction_threshold_pct": 0.7,
        "max_retries": null,
        "max_tokens": null,
        "max_tool_calls": null,
        "max_wall_seconds": null
      }
    },
    "exposed_tools": {
      "items": {
        "$ref": "#/$defs/ToolPermission"
      },
      "title": "Exposed Tools",
      "type": "array"
    },
    "harness_condition_id": {
      "minLength": 1,
      "title": "Harness Condition Id",
      "type": "string"
    },
    "manifest_hashes": {
      "items": {
        "$ref": "#/$defs/ManifestHash"
      },
      "title": "Manifest Hashes",
      "type": "array"
    },
    "model_backend": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelBackendRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "network_policy": {
      "default": "deny-by-default",
      "title": "Network Policy",
      "type": "string"
    },
    "permission_profile": {
      "default": "read-only",
      "title": "Permission Profile",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy",
      "default": {
        "hash_paths": true,
        "policy_id": "default",
        "redact_command_output": false,
        "redact_prompts": true,
        "redact_source_files": false
      }
    },
    "retry_policy": {
      "$ref": "#/$defs/RetryPolicy",
      "default": {
        "backoff_strategy": "none",
        "max_retries": 3
      }
    },
    "run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeRef"
    },
    "sampling_capability": {
      "default": "unknown",
      "title": "Sampling Capability",
      "type": "string"
    },
    "sandbox": {
      "$ref": "#/$defs/SandboxDescriptor",
      "default": {
        "devcontainer_sha": null,
        "notes": null,
        "sandbox_type": "none"
      }
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "supply_chain_refs": {
      "items": {
        "type": "string"
      },
      "title": "Supply Chain Refs",
      "type": "array"
    },
    "telemetry_location": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Telemetry Location"
    },
    "toolset_hash": {
      "default": "unknown",
      "title": "Toolset Hash",
      "type": "string"
    },
    "verification_gates": {
      "items": {
        "$ref": "#/$defs/VerificationGate"
      },
      "title": "Verification Gates",
      "type": "array"
    }
  },
  "required": [
    "harness_condition_id",
    "captured_ts",
    "runtime",
    "provenance"
  ],
  "title": "HarnessCondition",
  "type": "object"
}
