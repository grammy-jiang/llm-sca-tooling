{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "graph_chunk",
        "sarif",
        "trace",
        "diff",
        "test_output",
        "log",
        "summary",
        "report",
        "schema",
        "other"
      ],
      "title": "ArtifactKind",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "description": "Reference to an external artefact (SARIF report, trace file, diff, etc.).",
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "created_ts": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created Ts"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "size_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Bytes"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "uri",
        "redaction_status"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "DerivationType": {
      "enum": [
        "parser",
        "analyser",
        "build",
        "test",
        "trace",
        "llm",
        "heuristic",
        "policy",
        "review"
      ],
      "title": "DerivationType",
      "type": "string"
    },
    "EvidenceItem": {
      "additionalProperties": false,
      "properties": {
        "artifact_refs": {
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "title": "Artifact Refs",
          "type": "array"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "provenance": {
          "$ref": "#/$defs/Provenance"
        },
        "refs": {
          "items": {
            "type": "string"
          },
          "title": "Refs",
          "type": "array"
        },
        "strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "supports": {
          "$ref": "#/$defs/EvidenceSupport"
        }
      },
      "required": [
        "evidence_id",
        "kind",
        "supports",
        "strength",
        "confidence",
        "provenance"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "EvidenceStrength": {
      "description": "Ordered from strongest to weakest.\n\nThe numeric ordering supports comparisons:\n``EvidenceStrength.hard_static > EvidenceStrength.soft_llm`` is True.\n``min([hard_static, soft_llm])`` returns ``soft_llm``.",
      "enum": [
        "hard_static",
        "hard_dynamic",
        "structured_repository",
        "calibrated_model",
        "soft_llm"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "EvidenceSupport": {
      "enum": [
        "supports",
        "contradicts",
        "neutral",
        "context"
      ],
      "title": "EvidenceSupport",
      "type": "string"
    },
    "IndexStatus": {
      "enum": [
        "fresh",
        "stale",
        "partial",
        "mixed",
        "unknown"
      ],
      "title": "IndexStatus",
      "type": "string"
    },
    "MissingEvidence": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "title": "Description",
          "type": "string"
        },
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "forces_unknown": {
          "default": false,
          "title": "Forces Unknown",
          "type": "boolean"
        },
        "required_for": {
          "title": "Required For",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "required_for",
        "description"
      ],
      "title": "MissingEvidence",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Evidence provenance — required on every durable fact.\n\nEvery code-related fact must carry ``repo`` and ``snapshot``.\nLLM-derived evidence (``derivation=llm``) cannot claim hard evidence\nstrength (``hard_static`` or ``hard_dynamic``).",
      "properties": {
        "attributes": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Attributes",
          "type": "object"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_ts": {
          "minLength": 1,
          "title": "Created Ts",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/DerivationType"
        },
        "evidence_strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "repo": {
          "$ref": "#/$defs/RepoRef"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotRef"
        },
        "source_event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Event Id"
        },
        "source_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_tool": {
          "minLength": 1,
          "title": "Source Tool",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_tool",
        "repo",
        "snapshot",
        "derivation",
        "confidence",
        "evidence_strength",
        "created_ts"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_required",
        "redacted",
        "hash_only",
        "blocked",
        "unknown"
      ],
      "title": "RedactionStatus",
      "type": "string"
    },
    "RepoRef": {
      "additionalProperties": false,
      "description": "Stable reference to a repository.",
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "SnapshotConsistency": {
      "enum": [
        "clean",
        "dirty",
        "stale",
        "mixed",
        "unknown"
      ],
      "title": "SnapshotConsistency",
      "type": "string"
    },
    "SnapshotRef": {
      "additionalProperties": false,
      "description": "Reference to a specific repository snapshot.",
      "properties": {
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "captured_ts": {
          "minLength": 1,
          "title": "Captured Ts",
          "type": "string"
        },
        "dirty": {
          "default": false,
          "title": "Dirty",
          "type": "boolean"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "index_status": {
          "$ref": "#/$defs/IndexStatus",
          "default": "unknown"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "worktree_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worktree Snapshot Id"
        }
      },
      "required": [
        "repo_id",
        "captured_ts"
      ],
      "title": "SnapshotRef",
      "type": "object"
    },
    "SourceSpan": {
      "additionalProperties": false,
      "description": "Source location within a repository-relative file.",
      "properties": {
        "byte_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte End"
        },
        "byte_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte Start"
        },
        "encoding": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "end_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Col"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "file_path": {
          "minLength": 1,
          "title": "File Path",
          "type": "string"
        },
        "start_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Col"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "file_path",
        "start_line",
        "end_line"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "StaleEvidence": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "forces_unknown": {
          "default": false,
          "title": "Forces Unknown",
          "type": "boolean"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "stale_refs": {
          "items": {
            "type": "string"
          },
          "title": "Stale Refs",
          "type": "array"
        }
      },
      "required": [
        "evidence_id",
        "reason"
      ],
      "title": "StaleEvidence",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "An auditable collection of evidence items for a verdict subject.",
  "properties": {
    "aggregate_strength": {
      "$ref": "#/$defs/EvidenceStrength",
      "default": "soft_llm"
    },
    "bundle_id": {
      "minLength": 1,
      "title": "Bundle Id",
      "type": "string"
    },
    "created_ts": {
      "minLength": 1,
      "title": "Created Ts",
      "type": "string"
    },
    "evidence_items": {
      "items": {
        "$ref": "#/$defs/EvidenceItem"
      },
      "title": "Evidence Items",
      "type": "array"
    },
    "missing_evidence": {
      "items": {
        "$ref": "#/$defs/MissingEvidence"
      },
      "title": "Missing Evidence",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "snapshot_consistency": {
      "$ref": "#/$defs/SnapshotConsistency",
      "default": "unknown"
    },
    "stale_evidence": {
      "items": {
        "$ref": "#/$defs/StaleEvidence"
      },
      "title": "Stale Evidence",
      "type": "array"
    },
    "subject_ref": {
      "minLength": 1,
      "title": "Subject Ref",
      "type": "string"
    }
  },
  "required": [
    "bundle_id",
    "subject_ref",
    "created_ts",
    "provenance"
  ],
  "title": "EvidenceBundle",
  "type": "object"
}
