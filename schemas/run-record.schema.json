{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "graph_chunk",
        "sarif",
        "trace",
        "diff",
        "test_output",
        "log",
        "summary",
        "report",
        "schema",
        "other"
      ],
      "title": "ArtifactKind",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "description": "Reference to an external artefact (SARIF report, trace file, diff, etc.).",
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "created_ts": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created Ts"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "size_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Bytes"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "uri",
        "redaction_status"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "ContextBudget": {
      "additionalProperties": false,
      "properties": {
        "compaction_threshold_pct": {
          "default": 0.7,
          "title": "Compaction Threshold Pct",
          "type": "number"
        },
        "max_retries": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Retries"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "max_tool_calls": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tool Calls"
        },
        "max_wall_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Wall Seconds"
        }
      },
      "title": "ContextBudget",
      "type": "object"
    },
    "RedactionPolicy": {
      "additionalProperties": false,
      "properties": {
        "hash_paths": {
          "default": true,
          "title": "Hash Paths",
          "type": "boolean"
        },
        "policy_id": {
          "default": "default",
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "redact_command_output": {
          "default": false,
          "title": "Redact Command Output",
          "type": "boolean"
        },
        "redact_prompts": {
          "default": true,
          "title": "Redact Prompts",
          "type": "boolean"
        },
        "redact_source_files": {
          "default": false,
          "title": "Redact Source Files",
          "type": "boolean"
        }
      },
      "title": "RedactionPolicy",
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_required",
        "redacted",
        "hash_only",
        "blocked",
        "unknown"
      ],
      "title": "RedactionStatus",
      "type": "string"
    },
    "RepoRef": {
      "additionalProperties": false,
      "description": "Stable reference to a repository.",
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "RunStatus": {
      "enum": [
        "created",
        "running",
        "blocked",
        "failed",
        "completed",
        "cancelled",
        "unknown",
        "budget-exhausted"
      ],
      "title": "RunStatus",
      "type": "string"
    },
    "RunWorkflow": {
      "enum": [
        "implementation-check",
        "bug-resolve",
        "patch-review",
        "operational-review",
        "readiness-audit",
        "eval",
        "graph-build",
        "graph-update",
        "other"
      ],
      "title": "RunWorkflow",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "context_budget": {
      "$ref": "#/$defs/ContextBudget",
      "default": {
        "compaction_threshold_pct": 0.7,
        "max_retries": null,
        "max_tokens": null,
        "max_tool_calls": null,
        "max_wall_seconds": null
      }
    },
    "created_ts": {
      "minLength": 1,
      "title": "Created Ts",
      "type": "string"
    },
    "end_ts": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "End Ts"
    },
    "final_verdict_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Final Verdict Id"
    },
    "harness_condition_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Harness Condition Id"
    },
    "incident_ids": {
      "items": {
        "type": "string"
      },
      "title": "Incident Ids",
      "type": "array"
    },
    "model_backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Backend"
    },
    "permission_profile": {
      "default": "read-only",
      "title": "Permission Profile",
      "type": "string"
    },
    "policy_id": {
      "default": "unknown",
      "title": "Policy Id",
      "type": "string"
    },
    "redaction_policy": {
      "$ref": "#/$defs/RedactionPolicy",
      "default": {
        "hash_paths": true,
        "policy_id": "default",
        "redact_command_output": false,
        "redact_prompts": true,
        "redact_source_files": false
      }
    },
    "repos": {
      "items": {
        "$ref": "#/$defs/RepoRef"
      },
      "title": "Repos",
      "type": "array"
    },
    "run_event_count": {
      "default": 0,
      "title": "Run Event Count",
      "type": "integer"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_family": {
      "default": "run-record",
      "title": "Schema Family",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "start_ts": {
      "minLength": 1,
      "title": "Start Ts",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RunStatus",
      "default": "created"
    },
    "toolset_hash": {
      "default": "unknown",
      "title": "Toolset Hash",
      "type": "string"
    },
    "user_intent_hash": {
      "default": "",
      "title": "User Intent Hash",
      "type": "string"
    },
    "workflow": {
      "$ref": "#/$defs/RunWorkflow",
      "default": "other"
    }
  },
  "required": [
    "run_id",
    "start_ts",
    "created_ts"
  ],
  "title": "RunRecord",
  "type": "object"
}
