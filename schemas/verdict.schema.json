{
  "$defs": {
    "CalibrationRef": {
      "additionalProperties": false,
      "properties": {
        "calibration_id": {
          "description": "Calibration record identifier.",
          "minLength": 1,
          "title": "Calibration Id",
          "type": "string"
        },
        "ece": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ece"
        },
        "family": {
          "minLength": 1,
          "title": "Family",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "calibration_id",
        "family",
        "version"
      ],
      "title": "CalibrationRef",
      "type": "object"
    },
    "DerivationType": {
      "enum": [
        "parser",
        "analyser",
        "build",
        "test",
        "trace",
        "llm",
        "heuristic",
        "policy",
        "review"
      ],
      "title": "DerivationType",
      "type": "string"
    },
    "EvidenceStrength": {
      "enum": [
        "hard_static",
        "hard_dynamic",
        "structured_repository",
        "calibrated_model",
        "soft_llm"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "IndexStatus": {
      "enum": [
        "fresh",
        "stale",
        "partial",
        "mixed",
        "unknown"
      ],
      "title": "IndexStatus",
      "type": "string"
    },
    "PolicyAction": {
      "enum": [
        "allow",
        "deny",
        "approval_required",
        "blocked",
        "checkpoint",
        "force_unknown",
        "not_applicable"
      ],
      "title": "PolicyAction",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_ts": {
          "minLength": 1,
          "title": "Created Ts",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/DerivationType"
        },
        "evidence_strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "repo": {
          "$ref": "#/$defs/RepoRef"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotRef"
        },
        "source_event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Event Id"
        },
        "source_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_tool": {
          "minLength": 1,
          "title": "Source Tool",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_tool",
        "repo",
        "snapshot",
        "derivation",
        "confidence",
        "evidence_strength",
        "created_ts"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ReasoningStep": {
      "additionalProperties": false,
      "properties": {
        "claim": {
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "step_id": {
          "description": "Reasoning step identifier.",
          "minLength": 1,
          "title": "Step Id",
          "type": "string"
        },
        "strength": {
          "$ref": "#/$defs/EvidenceStrength"
        }
      },
      "required": [
        "step_id",
        "claim",
        "strength"
      ],
      "title": "ReasoningStep",
      "type": "object"
    },
    "RepoRef": {
      "additionalProperties": false,
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "description": "Stable repository identifier.",
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "SnapshotRef": {
      "additionalProperties": false,
      "properties": {
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "captured_ts": {
          "minLength": 1,
          "title": "Captured Ts",
          "type": "string"
        },
        "dirty": {
          "title": "Dirty",
          "type": "boolean"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "index_status": {
          "$ref": "#/$defs/IndexStatus"
        },
        "repo_id": {
          "description": "Repository identifier for this snapshot.",
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "worktree_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worktree Snapshot Id"
        }
      },
      "required": [
        "repo_id",
        "dirty",
        "index_status",
        "captured_ts"
      ],
      "title": "SnapshotRef",
      "type": "object"
    },
    "SourceSpan": {
      "additionalProperties": false,
      "properties": {
        "byte_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte End"
        },
        "byte_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte Start"
        },
        "encoding": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "end_col": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Col"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "file_path": {
          "title": "File Path",
          "type": "string"
        },
        "start_col": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Col"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "file_path",
        "start_line",
        "end_line"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "Uncertainty": {
      "additionalProperties": false,
      "properties": {
        "affected_refs": {
          "items": {
            "type": "string"
          },
          "title": "Affected Refs",
          "type": "array"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "forces_unknown": {
          "title": "Forces Unknown",
          "type": "boolean"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "description",
        "forces_unknown"
      ],
      "title": "Uncertainty",
      "type": "object"
    },
    "VerdictValue": {
      "enum": [
        "satisfied",
        "violated",
        "safe",
        "risky",
        "unknown",
        "process-compliant",
        "process-noncompliant",
        "trace-incomplete",
        "budget-exhausted",
        "needs-readiness-work"
      ],
      "title": "VerdictValue",
      "type": "string"
    }
  },
  "$id": "https://schemas.llm-sca.local/verdict.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Evidence-backed verdict contract.",
  "properties": {
    "calibration": {
      "anyOf": [
        {
          "$ref": "#/$defs/CalibrationRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "evidence_bundle_id": {
      "minLength": 1,
      "title": "Evidence Bundle Id",
      "type": "string"
    },
    "policy_action": {
      "$ref": "#/$defs/PolicyAction"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "reasoning_chain": {
      "items": {
        "$ref": "#/$defs/ReasoningStep"
      },
      "title": "Reasoning Chain",
      "type": "array"
    },
    "recommended_action": {
      "minLength": 1,
      "title": "Recommended Action",
      "type": "string"
    },
    "run_record_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Record Id"
    },
    "schema_family": {
      "const": "verdict",
      "default": "verdict",
      "title": "Schema Family",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "subject_ref": {
      "minLength": 1,
      "title": "Subject Ref",
      "type": "string"
    },
    "uncertainty": {
      "items": {
        "$ref": "#/$defs/Uncertainty"
      },
      "title": "Uncertainty",
      "type": "array"
    },
    "verdict": {
      "$ref": "#/$defs/VerdictValue"
    },
    "verdict_id": {
      "description": "Verdict identifier.",
      "minLength": 1,
      "title": "Verdict Id",
      "type": "string"
    },
    "workflow": {
      "minLength": 1,
      "title": "Workflow",
      "type": "string"
    }
  },
  "required": [
    "verdict_id",
    "workflow",
    "subject_ref",
    "verdict",
    "confidence",
    "evidence_bundle_id",
    "recommended_action",
    "policy_action",
    "provenance"
  ],
  "schema_family": "verdict",
  "schema_version": "0.1.0",
  "title": "Verdict schema",
  "type": "object"
}
