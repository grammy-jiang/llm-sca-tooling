{
  "$defs": {
    "AxisScore": {
      "additionalProperties": false,
      "properties": {
        "axis": {
          "$ref": "#/$defs/ReadinessAxis"
        },
        "score": {
          "maximum": 5,
          "minimum": 0,
          "title": "Score",
          "type": "integer"
        }
      },
      "required": [
        "axis",
        "score"
      ],
      "title": "AxisScore",
      "type": "object"
    },
    "DerivationType": {
      "enum": [
        "parser",
        "analyser",
        "build",
        "test",
        "trace",
        "llm",
        "heuristic",
        "policy",
        "review"
      ],
      "title": "DerivationType",
      "type": "string"
    },
    "EvidenceStrength": {
      "description": "Ordered from strongest to weakest.\n\nThe numeric ordering supports comparisons:\n``EvidenceStrength.hard_static > EvidenceStrength.soft_llm`` is True.\n``min([hard_static, soft_llm])`` returns ``soft_llm``.",
      "enum": [
        "hard_static",
        "hard_dynamic",
        "structured_repository",
        "calibrated_model",
        "soft_llm"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "HarnessStage": {
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3"
      ],
      "title": "HarnessStage",
      "type": "string"
    },
    "IndexStatus": {
      "enum": [
        "fresh",
        "stale",
        "partial",
        "mixed",
        "unknown"
      ],
      "title": "IndexStatus",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Evidence provenance — required on every durable fact.\n\nEvery code-related fact must carry ``repo`` and ``snapshot``.\nLLM-derived evidence (``derivation=llm``) cannot claim hard evidence\nstrength (``hard_static`` or ``hard_dynamic``).",
      "properties": {
        "attributes": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Attributes",
          "type": "object"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_ts": {
          "minLength": 1,
          "title": "Created Ts",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/DerivationType"
        },
        "evidence_strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "repo": {
          "$ref": "#/$defs/RepoRef"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotRef"
        },
        "source_event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Event Id"
        },
        "source_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_tool": {
          "minLength": 1,
          "title": "Source Tool",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_tool",
        "repo",
        "snapshot",
        "derivation",
        "confidence",
        "evidence_strength",
        "created_ts"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ReadinessAxis": {
      "enum": [
        "agent_config",
        "documentation",
        "ci_cd",
        "code_structure",
        "security"
      ],
      "title": "ReadinessAxis",
      "type": "string"
    },
    "RepoRef": {
      "additionalProperties": false,
      "description": "Stable reference to a repository.",
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "SnapshotRef": {
      "additionalProperties": false,
      "description": "Reference to a specific repository snapshot.",
      "properties": {
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "captured_ts": {
          "minLength": 1,
          "title": "Captured Ts",
          "type": "string"
        },
        "dirty": {
          "default": false,
          "title": "Dirty",
          "type": "boolean"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "index_status": {
          "$ref": "#/$defs/IndexStatus",
          "default": "unknown"
        },
        "repo_id": {
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "worktree_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worktree Snapshot Id"
        }
      },
      "required": [
        "repo_id",
        "captured_ts"
      ],
      "title": "SnapshotRef",
      "type": "object"
    },
    "SourceSpan": {
      "additionalProperties": false,
      "description": "Source location within a repository-relative file.",
      "properties": {
        "byte_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte End"
        },
        "byte_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte Start"
        },
        "encoding": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "end_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Col"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "file_path": {
          "minLength": 1,
          "title": "File Path",
          "type": "string"
        },
        "start_col": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Col"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "file_path",
        "start_line",
        "end_line"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "WaiverRecord": {
      "additionalProperties": false,
      "properties": {
        "axis": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReadinessAxis"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "owner": {
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "review_due_ts": {
          "minLength": 1,
          "title": "Review Due Ts",
          "type": "string"
        },
        "waiver_id": {
          "minLength": 1,
          "title": "Waiver Id",
          "type": "string"
        }
      },
      "required": [
        "waiver_id",
        "reason",
        "owner",
        "review_due_ts"
      ],
      "title": "WaiverRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "axis_scores": {
      "items": {
        "$ref": "#/$defs/AxisScore"
      },
      "title": "Axis Scores",
      "type": "array"
    },
    "history_refs": {
      "items": {
        "type": "string"
      },
      "title": "History Refs",
      "type": "array"
    },
    "missing_controls": {
      "items": {
        "type": "string"
      },
      "title": "Missing Controls",
      "type": "array"
    },
    "no_regression_result": {
      "default": "unknown",
      "title": "No Regression Result",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "readiness_report_id": {
      "minLength": 1,
      "title": "Readiness Report Id",
      "type": "string"
    },
    "repo": {
      "$ref": "#/$defs/RepoRef"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "stage": {
      "$ref": "#/$defs/HarnessStage"
    },
    "threshold_result": {
      "default": "unknown",
      "title": "Threshold Result",
      "type": "string"
    },
    "total_score": {
      "maximum": 25,
      "minimum": 0,
      "title": "Total Score",
      "type": "integer"
    },
    "waivers": {
      "items": {
        "$ref": "#/$defs/WaiverRecord"
      },
      "title": "Waivers",
      "type": "array"
    }
  },
  "required": [
    "readiness_report_id",
    "repo",
    "stage",
    "total_score",
    "axis_scores",
    "provenance"
  ],
  "title": "AIReadinessReport",
  "type": "object"
}