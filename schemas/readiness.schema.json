{
  "$defs": {
    "AxisScore": {
      "additionalProperties": false,
      "properties": {
        "axis": {
          "$ref": "#/$defs/ReadinessAxis"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "score": {
          "maximum": 5,
          "minimum": 0,
          "title": "Score",
          "type": "integer"
        }
      },
      "required": [
        "axis",
        "score"
      ],
      "title": "AxisScore",
      "type": "object"
    },
    "DerivationType": {
      "enum": [
        "parser",
        "analyser",
        "build",
        "test",
        "trace",
        "llm",
        "heuristic",
        "policy",
        "review"
      ],
      "title": "DerivationType",
      "type": "string"
    },
    "EvidenceStrength": {
      "enum": [
        "hard_static",
        "hard_dynamic",
        "structured_repository",
        "calibrated_model",
        "soft_llm"
      ],
      "title": "EvidenceStrength",
      "type": "string"
    },
    "HarnessStage": {
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3"
      ],
      "title": "HarnessStage",
      "type": "string"
    },
    "IndexStatus": {
      "enum": [
        "fresh",
        "stale",
        "partial",
        "mixed",
        "unknown"
      ],
      "title": "IndexStatus",
      "type": "string"
    },
    "NoRegressionResult": {
      "additionalProperties": false,
      "properties": {
        "incident_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Incident Id"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "waiver_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Waiver Id"
        }
      },
      "required": [
        "passed",
        "reason"
      ],
      "title": "NoRegressionResult",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_ts": {
          "minLength": 1,
          "title": "Created Ts",
          "type": "string"
        },
        "derivation": {
          "$ref": "#/$defs/DerivationType"
        },
        "evidence_strength": {
          "$ref": "#/$defs/EvidenceStrength"
        },
        "file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File"
        },
        "repo": {
          "$ref": "#/$defs/RepoRef"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotRef"
        },
        "source_event_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Event Id"
        },
        "source_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Run Id"
        },
        "source_tool": {
          "minLength": 1,
          "title": "Source Tool",
          "type": "string"
        },
        "source_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Version"
        },
        "span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpan"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "source_tool",
        "repo",
        "snapshot",
        "derivation",
        "confidence",
        "evidence_strength",
        "created_ts"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ReadinessAxis": {
      "enum": [
        "agent_config",
        "documentation",
        "ci_cd",
        "code_structure",
        "security"
      ],
      "title": "ReadinessAxis",
      "type": "string"
    },
    "RepoRef": {
      "additionalProperties": false,
      "properties": {
        "default_branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default Branch"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "remote_url_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remote Url Hash"
        },
        "repo_id": {
          "description": "Stable repository identifier.",
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "root_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Root Ref"
        }
      },
      "required": [
        "repo_id"
      ],
      "title": "RepoRef",
      "type": "object"
    },
    "SnapshotRef": {
      "additionalProperties": false,
      "properties": {
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "captured_ts": {
          "minLength": 1,
          "title": "Captured Ts",
          "type": "string"
        },
        "dirty": {
          "title": "Dirty",
          "type": "boolean"
        },
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "index_status": {
          "$ref": "#/$defs/IndexStatus"
        },
        "repo_id": {
          "description": "Repository identifier for this snapshot.",
          "minLength": 1,
          "title": "Repo Id",
          "type": "string"
        },
        "worktree_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Worktree Snapshot Id"
        }
      },
      "required": [
        "repo_id",
        "dirty",
        "index_status",
        "captured_ts"
      ],
      "title": "SnapshotRef",
      "type": "object"
    },
    "SourceSpan": {
      "additionalProperties": false,
      "properties": {
        "byte_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte End"
        },
        "byte_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Byte Start"
        },
        "encoding": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Encoding"
        },
        "end_col": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Col"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "file_path": {
          "title": "File Path",
          "type": "string"
        },
        "start_col": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Col"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "file_path",
        "start_line",
        "end_line"
      ],
      "title": "SourceSpan",
      "type": "object"
    },
    "ThresholdResult": {
      "additionalProperties": false,
      "properties": {
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "target_stage": {
          "$ref": "#/$defs/HarnessStage"
        }
      },
      "required": [
        "target_stage",
        "passed",
        "reason"
      ],
      "title": "ThresholdResult",
      "type": "object"
    },
    "WaiverRef": {
      "additionalProperties": false,
      "properties": {
        "expires_ts": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires Ts"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "reviewed_by": {
          "minLength": 1,
          "title": "Reviewed By",
          "type": "string"
        },
        "waiver_id": {
          "minLength": 1,
          "title": "Waiver Id",
          "type": "string"
        }
      },
      "required": [
        "waiver_id",
        "reviewed_by",
        "reason"
      ],
      "title": "WaiverRef",
      "type": "object"
    }
  },
  "$id": "https://schemas.llm-sca.local/readiness.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "AI-readiness report contract.",
  "properties": {
    "axis_scores": {
      "items": {
        "$ref": "#/$defs/AxisScore"
      },
      "title": "Axis Scores",
      "type": "array"
    },
    "history_refs": {
      "items": {
        "type": "string"
      },
      "title": "History Refs",
      "type": "array"
    },
    "missing_controls": {
      "items": {
        "type": "string"
      },
      "title": "Missing Controls",
      "type": "array"
    },
    "no_regression_result": {
      "$ref": "#/$defs/NoRegressionResult"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "readiness_report_id": {
      "description": "Readiness report identifier.",
      "minLength": 1,
      "title": "Readiness Report Id",
      "type": "string"
    },
    "repo": {
      "$ref": "#/$defs/RepoRef"
    },
    "schema_family": {
      "const": "readiness",
      "default": "readiness",
      "title": "Schema Family",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "stage": {
      "$ref": "#/$defs/HarnessStage"
    },
    "threshold_result": {
      "$ref": "#/$defs/ThresholdResult"
    },
    "total_score": {
      "maximum": 25,
      "minimum": 0,
      "title": "Total Score",
      "type": "integer"
    },
    "waivers": {
      "items": {
        "$ref": "#/$defs/WaiverRef"
      },
      "title": "Waivers",
      "type": "array"
    }
  },
  "required": [
    "readiness_report_id",
    "repo",
    "stage",
    "total_score",
    "axis_scores",
    "threshold_result",
    "no_regression_result",
    "provenance"
  ],
  "schema_family": "readiness",
  "schema_version": "0.1.0",
  "title": "Readiness schema",
  "type": "object"
}
