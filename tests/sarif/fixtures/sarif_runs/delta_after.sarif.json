{
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep",
          "rules": [
            {"id": "rule.same", "defaultConfiguration": {"level": "warning"}},
            {"id": "rule.shift", "defaultConfiguration": {"level": "warning"}},
            {"id": "rule.new", "defaultConfiguration": {"level": "error"}}
          ]
        }
      },
      "results": [
        {
          "ruleId": "rule.same",
          "level": "warning",
          "message": {"text": "same"},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/pkg/core.py"}, "region": {"startLine": 1}}}]
        },
        {
          "ruleId": "rule.shift",
          "level": "warning",
          "message": {"text": "shift"},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/pkg/core.py"}, "region": {"startLine": 7, "snippet": {"text": "after"}}}}]
        },
        {
          "ruleId": "rule.new",
          "level": "error",
          "message": {"text": "new"},
          "locations": [{"physicalLocation": {"artifactLocation": {"uri": "src/pkg/core.py"}, "region": {"startLine": 3}}}]
        }
      ]
    }
  ]
}
