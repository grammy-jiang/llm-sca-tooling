# Minimal fallback .gitignore (generated offline)
*.pyc
__pycache__/
*.egg-info/
dist/
build/
.eggs/
*.so
*.dylib
node_modules/
.DS_Store
Thumbs.db
*.log
.venv/
uv.lock.bak

# llm-sca runtime artifacts — ignore the whole workspace cache at any depth.
# This directory is generated by the MCP server and must not be tracked.
# Reviewed allowlist decision: MCP cache is ephemeral generated state (HC2).
.llm-sca/
**/.llm-sca/

# eval session traces in subdirectories
.agent/eval/traces/

# self-audit artifacts (MCP responses + driver helpers — session-specific)
.agent/artifacts/
.agent/run_self_audit.py

# external reference documents (not repo source)
docs/Designing Reliable Complex Skills*.md
docs/The-Complete-Guide-to-Building-Skill-for-Claude.md

# local-agent-harness (do not edit below this line)
.agent/logs/
.agent/traces/
.agent/runs/
.agent/eval/*.jsonl
.env
.env.*
*.pem
*.key
*.p12
*.pfx
